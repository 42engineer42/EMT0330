  {
    "id": "fn_conv_parse",
    "type": "function",
    "z": "flow_conveyor",
    "name": "Parse main controller",
    "func": "const d = msg.payload;\n\nfunction fmtDur(ms) {\n    if (!ms && ms !== 0) return '00:00:00';\n    const s = Math.floor(ms / 1000);\n    const h = Math.floor(s / 3600);\n    const m = Math.floor((s % 3600) / 60);\n    const sc = s % 60;\n    return [h,m,sc].map(v=>String(v).padStart(2,'0')).join(':');\n}\n\nconst maintPct = d.maintenance_threshold_ms > 0\n    ? Math.min(100, (d.tracked_work_ms / d.maintenance_threshold_ms) * 100)\n    : 0;\n\n// Check IMU vibration maintenance from flow context (set by imu store fn)\nconst imuVibMaint = flow.get('imu_vib_maintenance') || false;\n\n// Override machine state if IMU requires maintenance\nconst effectiveMaint = d.maintenance_required || imuVibMaint;\nconst effectiveState = effectiveMaint ? 'maintenance' : d.machine_state;\n\n// Inject merged state back into payload for the detail template\nconst merged = Object.assign({}, d, {\n    maintenance_required: effectiveMaint,\n    machine_state: effectiveState,\n    imu_vibration_maintenance: imuVibMaint\n});\n\nreturn [\n    [{ payload: parseFloat(Number(d.current_ma || 0).toFixed(1)) }],\n    [{ payload: d.speed || 0 }],\n    [{ payload: parseFloat(Number(d.util_pct || 0).toFixed(1)) }],\n    [{ payload: parseFloat(maintPct.toFixed(1)) }],\n    [{ payload: effectiveMaint ? 'YES ⚠' : 'OK ✓' }],\n    [{ payload: fmtDur(d.work_ms) }],\n    [{ payload: fmtDur(d.tracked_work_ms) }],\n    [{ payload: merged }]\n];\n",
    "outputs": 8,
    "x": 410,
    "y": 80,
    "wires": [
      [
        "gauge_current",
        "chart_current"
      ],
      [
        "gauge_speed"
      ],
      [
        "gauge_util"
      ],
      [
        "gauge_maint_conv"
      ],
      [
        "txt_maint_conv"
      ],
      [
        "txt_worktime_conv"
      ],
      [
        "txt_tracked_conv"
      ],
      [
        "tmpl_esp32_detail",
        "fn_maint_alert_conv"
      ]
    ]
  },
