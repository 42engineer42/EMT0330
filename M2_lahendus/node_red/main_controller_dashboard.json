  {
    "id": "tmpl_esp32_detail",
    "type": "ui_template",
    "z": "flow_conveyor",
    "group": "grp_conv_detail",
    "name": "ESP32 Detail",
    "order": 1,
    "width": "12",
    "height": "10",
    "format": "<style>\n.dt{width:100%;border-collapse:collapse;font-size:13px;font-family:monospace}\n.dt td{padding:5px 10px;border-bottom:1px solid rgba(128,128,128,0.1)}\n.dt tr:last-child td{border-bottom:none}\n.dt .l{color:#888;font-family:sans-serif;width:55%}\n.dt .v{font-weight:600}\n.bw{background:#d4edda;color:#155724;padding:2px 9px;border-radius:10px;font-size:11px;font-family:sans-serif}\n.bi{background:#fff3cd;color:#856404;padding:2px 9px;border-radius:10px;font-size:11px;font-family:sans-serif}\n.bm{background:#f8d7da;color:#721c24;padding:2px 9px;border-radius:10px;font-size:11px;font-family:sans-serif}\n.sec{font-size:10px;font-weight:600;letter-spacing:.08em;color:#aaa;font-family:sans-serif;padding:8px 10px 2px;text-transform:uppercase}\n</style>\n<table class=\"dt\">\n<tr><td colspan=\"2\" class=\"sec\">Machine</td></tr>\n<tr><td class=\"l\">Uptime</td><td class=\"v\">{{msg.payload.ms}} ms</td></tr>\n<tr><td class=\"l\">Machine state</td><td class=\"v\">\n  <span ng-class=\"{'bw':msg.payload.machine_state==='working','bi':msg.payload.machine_state==='idle','bm':msg.payload.machine_state==='maintenance'}\">{{msg.payload.machine_state}}</span>\n</td></tr>\n<tr><td class=\"l\">Motor maintenance</td><td class=\"v\">\n  <span ng-class=\"msg.payload.maintenance_required && !msg.payload.imu_vibration_maintenance ? 'bm' : 'bw'\">\n    {{msg.payload.maintenance_required && !msg.payload.imu_vibration_maintenance ? 'YES ⚠' : 'OK ✓'}}\n  </span>\n</td></tr>\n<tr><td class=\"l\">Vibration maintenance</td><td class=\"v\">\n  <span ng-class=\"msg.payload.imu_vibration_maintenance ? 'bm' : 'bw'\">\n    {{msg.payload.imu_vibration_maintenance ? 'YES ⚠' : 'OK ✓'}}\n  </span>\n</td></tr>\n<tr><td colspan=\"2\" class=\"sec\">Motor</td></tr>\n<tr><td class=\"l\">Applied speed</td><td class=\"v\">{{msg.payload.speed}} / 255</td></tr>\n<tr><td class=\"l\">Requested speed</td><td class=\"v\">{{msg.payload.requested_speed}} / 255</td></tr>\n<tr><td class=\"l\">Current