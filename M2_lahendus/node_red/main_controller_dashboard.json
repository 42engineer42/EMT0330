  {
    "id": "fn_bend_parse",
    "type": "function",
    "z": "flow_bending",
    "name": "Parse reset_button_2",
    "func": "const d = msg.payload;\n\nfunction fmtDur(ms) {\n    if (!ms && ms !== 0) return '00:00:00';\n    const s = Math.floor(ms / 1000);\n    const h = Math.floor(s / 3600);\n    const m = Math.floor((s % 3600) / 60);\n    const sc = s % 60;\n    return [h,m,sc].map(v=>String(v).padStart(2,'0')).join(':');\n}\n\nconst maintPct = d.maintenance_threshold_ms > 0\n    ? Math.min(100, (d.tracked_work_ms / d.maintenance_threshold_ms) * 100)\n    : 0;\n\nreturn [\n    [{ payload: parseFloat(maintPct.toFixed(1)) }],\n    [{ payload: d.maintenance_required ? 'YES ⚠' : 'OK ✓' }],\n    [{ payload: fmtDur(d.tracked_work_ms) }],\n    [{ payload: d }]\n];\n",
    "outputs": 4,
    "x": 400,
    "y": 80,
    "wires": [
      [
        "gauge_maint_bend"
      ],
      [
        "txt_maint_bend"
      ],
      [
        "txt_tracked_bend"
      ],
      [
        "tmpl_bend_detail",
        "fn_bend_alert"
      ]
    ]
  },
