    "func": "flow.set('ts_main', Date.now());\nflow.set('d_main', {\n    speed: msg.payload.speed || 0,\n    current_ma: msg.payload.current_ma || 0,\n    util_pct: msg.payload.util_pct || 0,\n    tracked_work_ms: msg.payload.tracked_work_ms || 0,\n    maintenance_required: msg.payload.maintenance_required || false,\n    machine_state: msg.payload.machine_state || 'idle'\n});\nreturn msg;",
