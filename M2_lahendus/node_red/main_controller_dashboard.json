  {
    "id": "tmpl_imu",
    "type": "ui_template",
    "z": "flow_conveyor",
    "group": "grp_conv_imu",
    "name": "IMU & Environment",
    "order": 1,
    "width": "6",
    "height": "12",
    "format": "<style>\n.imu{width:100%;border-collapse:collapse;font-size:13px;font-family:monospace}\n.imu td{padding:5px 10px;border-bottom:1px solid rgba(128,128,128,0.1)}\n.imu tr:last-child td{border-bottom:none}\n.imu .l{color:#888;font-family:sans-serif;width:55%}\n.imu .v{font-weight:600}\n.sec{font-size:10px;font-weight:600;letter-spacing:.08em;color:#aaa;font-family:sans-serif;padding:8px 10px 2px;text-transform:uppercase}\n.vib-ok{background:#d4edda;color:#155724;padding:2px 9px;border-radius:10px;font-size:11px;font-family:sans-serif}\n.vib-warn{background:#fff3cd;color:#856404;padding:2px 9px;border-radius:10px;font-size:11px;font-family:sans-serif}\n.vib-maint{background:#f8d7da;color:#721c24;padding:2px 9px;border-radius:10px;font-size:11px;font-family:sans-serif}\n</style>\n<table class=\"imu\">\n  <tr><td colspan=\"2\" class=\"sec\">Vibration</td></tr>\n  <tr><td class=\"l\">RMS linear accel</td><td class=\"v\">{{msg.payload.vibration.rms | number:3}} m/s²</td></tr>\n  <tr><td class=\"l\">Exceeding threshold</td><td class=\"v\">\n    <span ng-class=\"msg.payload.vibration.exceeding ? 'vib-warn' : 'vib-ok'\">\n      {{msg.payload.vibration.exceeding ? 'YES' : 'no'}}\n    </span>\n  </td></tr>\n  <tr><td class=\"l\">Vibration maintenance</td><td class=\"v\">\n    <span ng-class=\"msg.payload.vibration.maintenance_required ? 'vib-maint' : 'vib-ok'\">\n      {{msg.payload.vibration.maintenance_required ? 'REQUIRED ⚠' : 'OK ✓'}}\n    </span>\n  </td></tr>\n  <tr><td colspan=\"2\" class=\"sec\">Environment</td></tr>\n  <tr><td class=\"l\">Temperature</td><td class=\"v\">{{msg.payload.temp_c | number:1}} °C</td></tr>\n  <tr><td class=\"l\">Humidity</td><td class=\"v\">{{msg.payload.humidity_pct | number:1}} %</td></tr>\n  <tr><td class=\"l\">Pressure</td><td class=\"v\">{{msg.payload.pressure_hpa | number:1}} hPa</td></tr>\n  <tr><td class=\"l\">Altitude</td><td class=\"v\">{{msg.payload.alt_m | number:1}} m</td></tr>\n  <tr><td colspan=\"2\" class=\"sec\">Orientation</td></tr>\n  <tr><td class=\"l\">Yaw</td><td class=\"v\">{{msg.payload.orientation.yaw | number:1}}°</td></tr>\n  <tr><td class=\"l\">Pitch</td><td class=\"v\">{{msg.payload.orientation.pitch | number:1}}°</td></tr>\n  <tr><td class=\"l\">Roll</td><td class=\"v\">{{msg.payload.orientation.roll | number:1}}°</td></tr>\n  <tr><td colspan=\"2\" class=\"sec\">Acceleration (m/s²)</td></tr>\n  <tr><td class=\"l\">X / Y / Z</td><td class=\"v\">{{msg.payload.accel.x|number:2}} / {{msg.payload.accel.y|number:2}} / {{msg.payload.accel.z|number:2}}</td></tr>\n  <tr><td colspan=\"2\" class=\"sec\">Linear Accel (m/s²)</td></tr>\n  <tr><td class=\"l\">X / Y / Z</td><td class=\"v\">{{msg.payload.linear.x|number:2}} / {{msg.payload.linear.y|number:2}} / {{msg.payload.linear.z|number:2}}</td></tr>\n  <tr><td colspan=\"2\" class=\"sec\">Gyroscope (rad/s)</td></tr>\n  <tr><td class=\"l\">X / Y / Z</td><td class=\"v\">{{msg.payload.gyro.x|number:2}} / {{msg.payload.gyro.y|number:2}} / {{msg.payload.gyro.z|number:2}}</td></tr>\n  <tr><td colspan=\"2\" class=\"sec\">Gravity (m/s²)</td></tr>\n  <tr><td class=\"l\">X / Y / Z</td><td class=\"v\">{{msg.payload.gravity.x|number:2}} / {{msg.payload.gravity.y|number:2}} / {{msg.payload.gravity.z|number:2}}</td></tr>\n</table>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "x": 400,
