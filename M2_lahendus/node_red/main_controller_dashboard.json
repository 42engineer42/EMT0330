  {
    "id": "fn_store_imu",
    "type": "function",
    "z": "flow_overview",
    "name": "Store imu_controller",
    "func": "flow.set('ts_imu', Date.now());\n\nconst vib = msg.payload.vibration || {};\nconst vibMaint = vib.maintenance_required === true;\n\nflow.set('imu_vib_maintenance', vibMaint);\nflow.set('d_imu', {\n    temp_c: msg.payload.temp_c,\n    roll:  msg.payload.orientation ? msg.payload.orientation.roll  : null,\n    pitch: msg.payload.orientation ? msg.payload.orientation.pitch : null,\n    maintenance_required: vibMaint,\n    machine_state: vibMaint ? 'maintenance' : 'idle'\n});\nreturn msg;",
    "outputs": 1,
    "x": 420,
    "y": 200,
    "wires": [
      [
        "fn_overview_agg"
      ]
    ]
  },
