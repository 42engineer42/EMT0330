  {
    "id": "fn_overview_agg",
    "type": "function",
    "z": "flow_overview",
    "name": "Aggregate all machines",
    "func": "const TIMEOUT = 10000;\nconst now = Date.now();\n\nfunction online(key) {\n    const ts = flow.get(key);\n    return !!(ts && (now - ts) < TIMEOUT);\n}\n\nfunction fmtDur(ms) {\n    if (!ms) return '00:00:00';\n    const s = Math.floor(ms / 1000);\n    const h = Math.floor(s / 3600);\n    const m = Math.floor((s % 3600) / 60);\n    const sc = s % 60;\n    return [h,m,sc].map(v=>String(v).padStart(2,'0')).join(':');\n}\n\nconst mainOn   = online('ts_main');\nconst reset1On = online('ts_reset1');\nconst imuOn    = online('ts_imu');\nconst reset2On = online('ts_reset2');\n\nconst dMain   = flow.get('d_main')   || {};\nconst dReset1 = flow.get('d_reset1') || {};\nconst dImu    = flow.get('d_imu')    || {};\nconst dReset2 = flow.get('d_reset2') || {};\n\n// Conveyor state — priority: offline > maintenance > working > idle\nfunction conveyorState() {\n    if (!mainOn && !reset1On && !imuOn) return 'offline';\n    // maintenance: motor threshold OR imu vibration latch\n    if (dMain.maintenance_required || dReset1.maintenance_required || dImu.maintenance_required) {\n        return 'maintenance';\n    }\n    if (dMain.machine_state === 'working') return 'working';\n    return 'idle';\n}\n\nfunction bendingState() {\n    if (!reset2On) return 'offline';\n    if (dReset2.maintenance_required) return 'maintenance';\n    if (dReset2.machine_state === 'working') return 'working';\n    return 'idle';\n}\n\nmsg.payload = {\n    conveyor: {\n        state: conveyorState(),\n        esps: [\n            { name: 'Main ctrl', online: mainOn },\n            { name: 'Reset btn', online: reset1On },\n            { name: 'IMU',       online: imuOn }\n        ],\n        speed:      dMain.speed || 0,\n        current_ma: dMain.current_ma ? Number(dMain.current_ma).toFixed(0) : '—',\n        util_pct:   dMain.util_pct   ? Number(dMain.util_pct).toFixed(1)   : '—',\n        tracked:    fmtDur(dMain.tracked_work_ms),\n        temp_c:     dImu.temp_c != null ? Number(dImu.temp_c).toFixed(1) : '—',\n        roll:       dImu.roll   != null ? Number(dImu.roll).toFixed(1)   : '—'\n    },\n    bending: {\n        state: bendingState(),\n        esps: [ { name: 'Reset btn', online: reset2On } ],\n        tracked: fmtDur(dReset2.tracked_work_ms)\n    },\n    palletising: { state: 'offline', esps: [] },\n    cnc:         { state: 'offline', esps: [] }\n};\n\nreturn msg;\n",
    "outputs": 1,
    "x": 660,
    "y": 200,
    "wires": [
      [
        "tmpl_overview"
      ]
    ]
  },
  {
    "id": "tmpl_overview",
    "type": "ui_template",
    "z": "flow_overview",
    "group": "grp_overview",
    "name": "Overview Cards",
    "order": 1,
    "width": "12",
    "height": "5",
    "format": "<style>\n.ov{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;padding:8px 0}\n.mc{border-radius:14px;border:0.5px solid rgba(128,128,128,0.18);background:var(--color-background-primary,#fff);overflow:hidden;font-family:sans-serif;display:flex;flex-direction:column;align-items:center;padding:24px 16px 20px}\n.sq{width:120px;height:120px;border-radius:16px;cursor:pointer;transition:transform .12s,opacity .12s;display:flex;align-items:center;justify-content:center;text-decoration:none;margin-bottom:16px}\n.sq:hover{transform:scale(0.96);opacity:.9}\n.sq svg{width:48px;height:48px;opacity:0.75}\n.sq-working{background:#3B6D11}\n.sq-idle{background:#BA7517}\n.sq-maintenance{background:#A32D2D}\n.sq-offline{background:#5F5E5A}\n.mc-name{font-size:15px;font-weight:600;color:var(--color-text-primary,#111);margin-bottom:5px;text-align:center}\n.mc-state{font-size:12px;font-weight:600;letter-spacing:.07em;text-align:center}\n.st-working{color:#3B6D11}.st-idle{color:#854F0B}.st-maintenance{color:#A32D2D}.st-offline{color:#888}\n</style>\n\n<div class=\"ov\" ng-if=\"msg.payload\">\n\n  <div class=\"mc\">\n    <a class=\"sq\" ng-class=\"'sq-'+msg.payload.conveyor.state\" href=\"#!/Conveyor Belt\">\n      <svg viewBox=\"0 0 24 24\" fill=\"white\"><path d=\"M21 16H3a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1h18a1 1 0 0 1 1 1v6a1 1 0 0 1-1 1zm-1-6H4v4h16v-4zM5 18a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm14 0a2 2 0 1 1 0-4 2 2 0 0 1 0 4z\"/></svg>\n    </a>\n    <div class=\"mc-name\">Conveyor Belt</div>\n    <div class=\"mc-state\" ng-class=\"'st-'+msg.payload.conveyor.state\">{{msg.payload.conveyor.state | uppercase}}</div>\n  </div>\n\n  <div class=\"mc\">\n    <a class=\"sq\" ng-class=\"'sq-'+msg.payload.bending.state\" href=\"#!/Bending Machine\">\n      <svg viewBox=\"0 0 24 24\" fill=\"white\"><path d=\"M19.5 9.5A4.5 4.5 0 0 0 15 5H5v2h10a2.5 2.5 0 0 1 0 5H5v2h10a4.5 4.5 0 0 0 4.5-4.5zM5 19h14v-2H5v2z\"/></svg>\n    </a>\n    <div class=\"mc-name\">Bending Machine</div>\n    <div class=\"mc-state\" ng-class=\"'st-'+msg.payload.bending.state\">{{msg.payload.bending.state | uppercase}}</div>\n  </div>\n\n  <div class=\"mc\">\n    <a class=\"sq sq-offline\" href=\"#!/Palletising\">\n      <svg viewBox=\"0 0 24 24\" fill=\"white\"><path d=\"M21 8.5L12 3 3 8.5v7L12 21l9-5.5v-7zM12 5.31L19 9.5v5L12 18.69 5 14.5v-5L12 5.31z\"/></svg>\n    </a>\n    <div class=\"mc-name\">Palletising</div>\n    <div class=\"mc-state st-offline\">OFFLINE</div>\n  </div>\n\n  <div class=\"mc\">\n    <a class=\"sq sq-offline\" href=\"#!/CNC Machine\">\n      <svg viewBox=\"0 0 24 24\" fill=\"white\"><path d=\"M12 2a7 7 0 0 1 7 7c0 2.66-1.5 5-3.72 6.28L14 22H10l-1.28-6.72C6.5 14 5 11.66 5 9a7 7 0 0 1 7-7zm0 2a5 5 0 0 0-5 5c0 2.03 1.15 3.8 2.9 4.69L11 20h2l1.1-6.31A5.005 5.005 0 0 0 17 9a5 5 0 0 0-5-5z\"/></svg>\n    </a>\n    <div class=\"mc-name\">CNC Machine</div>\n    <div class=\"mc-state st-offline\">OFFLINE</div>\n  </div>\n\n</div>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "x": 880,
    "y": 200,
    "wires": [
