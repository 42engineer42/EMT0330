    "name": "Format IMU for charts",
    "func": "const d = msg.payload;\nconst t = Date.now();\n\nif (!d.linear || !d.vibration) return [null, null, null, null];\n\nreturn [\n    [{ topic: 'X', payload: parseFloat(Number(d.linear.x).toFixed(3)) }],\n    [{ topic: 'Y', payload: parseFloat(Number(d.linear.y).toFixed(3)) }],\n    [{ topic: 'Z', payload: parseFloat(Number(d.linear.z).toFixed(3)) }],\n    [{ topic: 'RMS', payload: parseFloat(Number(d.vibration.rms).toFixed(3)) }]\n];\n",
